{
  "manifest_version": 3,
  "name": "Chess.com Low Time Warning",
  "version": "2.0",
  "description": "Creates a breathing grid that moves depending on the time left on the clock. Also has the option to play sounds when the clock is low.",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Chess Timer Sounds"
  },
  "content_scripts": [
    {
      "matches": ["https://www.chess.com/*"],
      "js": ["three.min.js", "content.js"],
      "css": ["secondaryClock.css"]
    }
  ]
}
